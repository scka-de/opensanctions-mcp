# OpenSanctions MCP Server Configuration

# API key for the hosted OpenSanctions API (required for search, match, entities)
# Get a free key at https://www.opensanctions.org/api/
# Not needed for self-hosted yente or sandbox mode
OPENSANCTIONS_API_KEY=

# API URL (optional, defaults to hosted API)
# Set to your self-hosted yente instance URL if running locally
OPENSANCTIONS_API_URL=https://api.opensanctions.org

# Dataset to screen against (optional, defaults to "default" which includes all sources)
OPENSANCTIONS_DATASET=default

# Max retries for API calls (optional, defaults to 3)
OPENSANCTIONS_MAX_RETRIES=3

# Enable debug logging to stderr (optional)
DEBUG=
